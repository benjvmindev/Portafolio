---
const { title, description } = Astro.props;
---

<div class="bg-[#052659] p-4 md:p-6 rounded-lg border border-[#C1EBFF] transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-[#C1EBFF]/20 cursor-pointer">
    <h3 class="text-lg md:text-xl font-bold text-[#C1EBFF] mb-2">{title}</h3>
    <p class="text-sm md:text-base text-[#7DA0CA]">{description}</p>
</div>

